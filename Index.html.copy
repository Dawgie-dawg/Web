<script>
// Scroll reveals
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      observer.unobserve(e.target);
    }
  });
}, {threshold: 0.12});

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// Nav scroll
const navbar = document.getElementById('navbar');
const menuBtnWrap = document.getElementById('menuBtnWrap');
window.addEventListener('scroll', () => {
  const scrolled = window.scrollY > 50;
  navbar.classList.toggle('scrolled', scrolled);
  menuBtnWrap.classList.toggle('scrolled', scrolled);
}, {passive:true});

// Menu
const btn     = document.getElementById('menuBtn');
const overlay = document.getElementById('navOverlay');
const ml1     = document.getElementById('ml1');
const ml2     = document.getElementById('ml2');
const word    = document.getElementById('menuWord');

const REST1 = 32, REST2 = 16, ARM = 40;
let t1, t2, sk1, sk2;

function init() {
  t1 = ml1.getTotalLength();
  t2 = ml2.getTotalLength();
  sk1 = t1 - ARM;
  sk2 = t2 - ARM;
  ml1.style.strokeDasharray  = REST1 + ' ' + t1;
  ml1.style.strokeDashoffset = 0;
  ml2.style.strokeDasharray  = REST2 + ' ' + t2;
  ml2.style.strokeDashoffset = 0;
}

function openLines() {
  ml1.style.strokeDasharray  = ARM + ' ' + t1;
  ml1.style.strokeDashoffset = -sk1;
  ml2.style.strokeDasharray  = ARM + ' ' + t2;
  ml2.style.strokeDashoffset = -sk2;
}

function closeLines() {
  ml1.style.strokeDasharray  = REST1 + ' ' + t1;
  ml1.style.strokeDashoffset = 0;
  ml2.style.strokeDasharray  = REST2 + ' ' + t2;
  ml2.style.strokeDashoffset = 0;
}

window.addEventListener('load', init);

function openMenu() {
  btn.classList.add('morphing');
  openLines();
  // slight delay so gold flash is visible before panel opens
  setTimeout(() => {
    overlay.classList.add('open');
    btn.classList.add('open');
  }, 80);
  word.textContent = 'Close';
  document.body.style.overflow = 'hidden';
  setTimeout(() => btn.classList.remove('morphing'), 680);
}

function closeMenu() {
  btn.classList.add('morphing');
  closeLines();
  setTimeout(() => {
    overlay.classList.remove('open');
    btn.classList.remove('open');
  }, 80);
  word.textContent = 'Menu';
  document.body.style.overflow = '';
  setTimeout(() => btn.classList.remove('morphing'), 680);
}

btn.addEventListener('click', () => {
  if (overlay.classList.contains('open')) closeMenu();
  else openMenu();
});
overlay.addEventListener('click', (e) => {
  if (!e.target.closest('.nav-panel')) closeMenu();
});

// ── SECTOR SPLIT-SCREEN ──
(function(){
  const data = [
    { num:'01', name:'Janitorial &amp; Soft Services',   tag:'Core Focus',  desc:'Commercial cleaning, environmental services, and integrated soft FM businesses across office, healthcare, industrial, and institutional settings.' },
    { num:'02', name:'Hard Services &amp; Maintenance',  tag:'Core Focus',  desc:'Mechanical, electrical, plumbing, and HVAC service businesses — including planned preventative maintenance and reactive maintenance contracts.' },
    { num:'03', name:'Integrated FM',                    tag:'Core Focus',  desc:'Total facilities management providers delivering bundled hard and soft service solutions under a single contract structure.' },
    { num:'04', name:'Building Services',                tag:'Core Focus',  desc:'Concierge, security, front-of-house, and ancillary building services businesses operating in commercial real estate environments.' },
    { num:'05', name:'Landscaping &amp; Grounds',        tag:'Active',      desc:'Exterior maintenance, snow removal, and grounds management companies serving commercial, municipal, and institutional clients.' },
    { num:'06', name:'Pest Control &amp; Hygiene',       tag:'Active',      desc:'Specialist pest management and washroom hygiene service businesses with recurring contract revenue and route-based operations.' },
    { num:'07', name:'Waste &amp; Environmental',        tag:'Active',      desc:'Waste collection, recycling, and environmental compliance service businesses within managed facilities and commercial portfolios.' },
    { num:'08', name:'FM Technology &amp; CAFM',         tag:'Selective',   desc:'Software platforms, IoT-enabled maintenance tools, and tech-enabled FM businesses at the intersection of real estate and services.' },
  ];

  const items   = document.querySelectorAll('.spec-list-item');
  const content = document.getElementById('specPanelContent');
  const panelNum= document.getElementById('specPanelNum');
  const panelTag= document.getElementById('specPanelTag');
  const panelName=document.getElementById('specPanelName');
  const panelDesc=document.getElementById('specPanelDesc');
  if(!items.length) return;

  let current = 0;
  let animating = false;

  function activate(idx){
    if(idx === current || animating) return;
    animating = true;

    // Update list state
    items[current].classList.remove('active');
    items[idx].classList.add('active');
    current = idx;

    // Fade out
    content.classList.add('transitioning');

    setTimeout(() => {
      const d = data[idx];
      panelNum.textContent  = d.num;
      panelTag.textContent  = d.tag;
      panelName.innerHTML   = d.name;
      panelDesc.textContent = d.desc;
      // Fade in
      content.classList.remove('transitioning');
      animating = false;
    }, 350);
  }

  items.forEach((item, i) => {
    item.addEventListener('mouseenter', () => activate(i));
    item.addEventListener('click',      () => activate(i));
  });
})();
</script>
</body>
</html>
