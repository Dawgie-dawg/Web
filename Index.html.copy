<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
  <meta property="og:title" content="AGeorge &amp; Co. | M&amp;A Advisory">
  <meta property="og:description" content="Strategic, confidential advisory for principals. Specialist M&amp;A advisory for facility management businesses.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://dawgie-dawg.github.io/Web/">
  <meta property="og:image" content="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1200&q=85&fit=crop">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="AGeorge &amp; Co. | M&amp;A Advisory">
  <meta name="twitter:description" content="Strategic, confidential advisory for principals.">
  <meta name="twitter:image" content="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1200&q=85&fit=crop">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGeorge &amp; Co. | M&A Advisory</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
<style>
:root {
  --navy:      #47505e;
  --navy-2:    #4b5668;
  --navy-3:    #50596a;
  --gold:      #b8926a;
  --gold-lt:   #d4b896;
  --gold-dk:   #8a6540;
  --border:    rgba(248,247,245,0.08);
  --border-g:  rgba(184,146,106,0.22);
  --white:     #f8f7f5;
  --muted:     #7a8799;
  --parchment: #ffffff;
  --parchment-lt: #f8f7f5;
  --ink:       #1a1d24;
  --ink-2:     #3a3f4a;
  --ink-3:     #6b707c;
  /* ── Warm light section — near white, same warm family ── */
  --linen:        #f8f7f5;
  --linen-border: rgba(138,101,64,0.10);
  --linen-ink:    var(--ink);
  --linen-ink-2:  var(--ink-2);
  --linen-accent: var(--gold-dk);
  /* ── Solid hero-blue for flat sections ── */
  --hero-blue:    #142540;
  --hero-blue-lt: #1e3a5f;
}

*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:17px;}

body{
  font-family:'DM Sans',sans-serif;
  background:var(--hero-blue);
  color:var(--white);
  font-weight:400;
  line-height:1.65;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}

::selection{background:var(--gold);color:var(--navy);}

.wrap{
  max-width:1440px;
  margin:0 auto;
  padding:0 clamp(1.5rem,5vw,6rem);
}

/* ── NAV ── */
nav{
  position:fixed;
  top:0;left:0;right:0;
  z-index:300;
  padding:0 clamp(1.5rem,5vw,6rem);
  height:88px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  transition:height .45s ease,background .45s ease;
}

nav.scrolled{
  height:68px;
  background:#ffffff;
  box-shadow:0 4px 24px rgba(10,22,40,.09);
  border-bottom:1px solid rgba(138,101,64,.12);
}

nav.scrolled .nav-logo{color:var(--ink);}
nav.scrolled .nav-logo-amp{color:var(--gold-dk);}
.menu-btn-wrap.scrolled .m-line{stroke:var(--ink);}
.menu-btn-wrap.scrolled .menu-word{color:var(--ink-3);}

.nav-logo{
  font-family:'Instrument Serif',serif;
  font-size:1.45rem;
  font-weight:400;
  letter-spacing:.03em;
  color:var(--white);
  text-decoration:none;
  text-transform:uppercase;
  transition:opacity .3s ease;
}
.nav-logo:hover{opacity:.75;}
.nav-logo-amp{font-style:italic;color:var(--gold);}

/* ── MENU BTN — fixed independently, always on top ── */
.menu-btn{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:4px;
  background:none;
  border:none;
  cursor:pointer;
  padding:8px;
  position:fixed;
  top:0;
  right:clamp(1.5rem,5vw,6rem);
  height:88px;
  justify-content:center;
  z-index:600;
  transition:height .45s ease;
}
nav.scrolled ~ * .menu-btn,
nav.scrolled + .menu-btn-wrap .menu-btn{height:68px;}
.menu-btn-wrap{
  position:fixed;top:0;right:clamp(1.5rem,5vw,6rem);
  height:88px;display:flex;align-items:center;
  z-index:600;
  transition:height .45s ease;
}
.menu-btn-wrap.scrolled{height:68px;}
.m-line{
  fill:none;
  stroke:var(--white);
  stroke-width:1.6;
  stroke-linecap:round;
  transition:
    stroke-dasharray 600ms cubic-bezier(.4,0,.2,1),
    stroke-dashoffset 600ms cubic-bezier(.4,0,.2,1),
    stroke 200ms ease;
}

/* Gold during morph in both directions */
.menu-btn.morphing .m-line{stroke:var(--gold-lt) !important;}
.menu-btn.open      .m-line{stroke:var(--white);}

.m-line-1{stroke-dasharray:32 74;stroke-dashoffset:0;}
.m-line-2{stroke-dasharray:16 46;stroke-dashoffset:0;}
.menu-btn.open .m-line-1{stroke-dasharray:39 74;stroke-dashoffset:-32;}
.menu-btn.open .m-line-2{stroke-dasharray:27 46;stroke-dashoffset:-16;}

.menu-word{
  font-size:.54rem;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--muted);
  line-height:1;
  transition:opacity .25s ease;
}
.menu-btn.open .menu-word{opacity:.45;}

/* ── SLIDE PANEL ── */
.nav-overlay{
  position:fixed;inset:0;
  z-index:400;
  pointer-events:none;
}
.nav-overlay::before{
  content:'';
  position:absolute;inset:0;
  background:rgba(5,10,20,.55);
  opacity:0;
  transition:opacity .5s ease;
}
.nav-overlay.open{pointer-events:all;}
.nav-overlay.open::before{opacity:1;}

.nav-panel{
  position:absolute;
  top:0;right:0;
  width:min(90vw,440px);height:100%;
  background:var(--hero-blue);
  border-left:1px solid rgba(184,146,106,.15);
  transform:translateX(100%);
  transition:transform .6s cubic-bezier(.77,0,.175,1);
  display:flex;flex-direction:column;justify-content:center;
  padding:5rem 3.5rem 6rem;
  overflow-y:auto;
}
.nav-panel::after{
  content:'';
  position:absolute;top:0;left:0;
  width:2px;height:100%;
  background:linear-gradient(to bottom,var(--gold),transparent 70%);
  transform:scaleY(0);transform-origin:top;
  transition:transform .65s cubic-bezier(.77,0,.175,1) .22s;
}
.nav-overlay.open .nav-panel{transform:translateX(0);}
.nav-overlay.open .nav-panel::after{transform:scaleY(1);}

.nav-item{overflow:hidden;margin-bottom:.25rem;}
.nav-item a{
  display:block;
  font-family:'Instrument Serif',serif;
  font-size:clamp(1.5rem,3.5vw,2rem);
  font-weight:400;
  color:rgba(248,247,245,.62);
  text-decoration:none;
  padding:.4rem 0;
  border-bottom:1px solid var(--border);
  transform:translateY(110%);
  transition:color .3s ease;
}
.nav-item a:hover{color:var(--gold-lt);}

.nav-overlay.open .nav-item a{
  animation:navUp .6s cubic-bezier(.16,1,.3,1) forwards;
}
.nav-item:nth-child(1) a{animation-delay:.16s;}
.nav-item:nth-child(2) a{animation-delay:.23s;}
.nav-item:nth-child(3) a{animation-delay:.30s;}
.nav-item:nth-child(4) a{animation-delay:.37s;}

@keyframes navUp{
  from{transform:translateY(110%);opacity:0;}
  to{transform:translateY(0);opacity:1;}
}

.panel-foot{
  margin-top:2.5rem;padding-top:2rem;
  border-top:1px solid var(--border);
  opacity:0;transform:translateY(8px);
  transition:opacity .4s ease .5s,transform .4s ease .5s;
}
.nav-overlay.open .panel-foot{opacity:1;transform:translateY(0);}

.panel-contact{display:flex;flex-direction:column;gap:.8rem;}
.panel-contact-item{display:flex;flex-direction:column;gap:.15rem;}
.panel-contact-label{
  font-size:.55rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--gold);opacity:.7;font-weight:500;
}
.panel-contact-item a,
.panel-contact-item span{
  font-size:.85rem;
  color:rgba(248,247,245,.55);
  text-decoration:none;
  transition:color .3s ease;
  cursor:default;
}
.panel-contact-item a{cursor:pointer;}
.panel-contact-item a:hover,
.panel-contact-item span:hover{color:var(--gold-lt);}

/* ── HERO ── */
.hero{
  min-height:100vh;
  background:linear-gradient(135deg, #0d1d35 0%, #142540 35%, #1a3560 65%, #0f1e38 100%);
  display:flex;flex-direction:column;justify-content:center;
  padding:7rem clamp(1.5rem,5vw,6rem) 1rem;
  position:relative;overflow:hidden;
}
/* Visible grid */
.hero::before{
  content:'';
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(184,146,106,.10) 1px, transparent 1px),
    linear-gradient(90deg, rgba(184,146,106,.10) 1px, transparent 1px);
  background-size:72px 72px;
  mask-image:linear-gradient(to right, rgba(0,0,0,.85) 0%, rgba(0,0,0,.4) 55%, transparent 85%);
  -webkit-mask-image:linear-gradient(to right, rgba(0,0,0,.85) 0%, rgba(0,0,0,.4) 55%, transparent 85%);
  pointer-events:none;
}
/* Warm gold halo — upper right */
.hero::after{
  content:'';
  position:absolute;
  top:-20%;right:-10%;
  width:70%;height:90%;
  background:radial-gradient(ellipse at 70% 25%,rgba(184,146,106,.11) 0%,rgba(184,146,106,.04) 40%,transparent 68%);
  pointer-events:none;
}
/* Large ghost monogram */
.hero-bg-mono{
  position:absolute;
  right:-2%;bottom:-8%;
  font-family:'Instrument Serif',serif;
  font-size:clamp(22rem,38vw,46rem);
  font-weight:400;
  font-style:italic;
  color:transparent;
  -webkit-text-stroke:1px rgba(184,146,106,.07);
  line-height:1;
  pointer-events:none;
  user-select:none;
  letter-spacing:-.04em;
}

.hero-eyebrow{
  display:flex;align-items:center;gap:1rem;
  margin-bottom:2.2rem;
  opacity:0;animation:fadeUp .8s ease .3s forwards;
}
.hero-ey-line{width:28px;height:1px;background:var(--gold);opacity:.55;flex-shrink:0;}
.hero-ey-text{
  font-size:.7rem;letter-spacing:.28em;text-transform:uppercase;
  color:var(--gold-lt);font-weight:400;
}

.hero h1{
  font-family:'Instrument Serif',serif;
  font-size:clamp(3.4rem,7.5vw,7rem);
  font-weight:400;line-height:1.02;letter-spacing:-.03em;
  color:var(--white);max-width:1060px;
  opacity:0;animation:fadeUp .9s ease .45s forwards;
}
.hero h1 em{font-style:italic;color:var(--gold-lt);}

.hero-bottom{
  display:flex;justify-content:space-between;align-items:flex-end;
  margin-top:2rem;padding-top:1.5rem;
  opacity:0;animation:fadeUp .8s ease .65s forwards;
}
.hero-desc{
  max-width:440px;font-size:1.05rem;line-height:1.82;
  color:rgba(248,247,245,.48);font-weight:400;
}

.hero-cta{
  display:flex;align-items:center;gap:1.4rem;
  text-decoration:none;color:var(--white);flex-shrink:0;
  transition:gap .4s cubic-bezier(.4,0,.2,1);
}
.hero-cta:hover{gap:1.9rem;}
.hero-cta-label{font-size:.83rem;font-weight:500;letter-spacing:.04em;color:rgba(248,247,245,.68);}
.hero-cta-circle{
  width:52px;height:52px;border:1px solid var(--border-g);border-radius:50%;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  transition:all .4s cubic-bezier(.4,0,.2,1);
}
.hero-cta:hover .hero-cta-circle{background:var(--gold);border-color:var(--gold);}
.hero-cta-circle svg{
  width:16px;height:16px;stroke:rgba(248,247,245,.55);transition:all .4s ease;
}
.hero-cta:hover .hero-cta-circle svg{stroke:var(--navy);transform:translateX(2px);}

@keyframes fadeUp{
  from{opacity:0;transform:translateY(22px);}
  to{opacity:1;transform:translateY(0);}
}

/* ── MARQUEE ── */
.marquee-wrap{
  overflow:hidden;
  padding:2.6rem 0;
  background:var(--hero-blue-lt);
  border-top:none;
  border-bottom:none;
}
.marquee-track{display:flex;animation:marquee 32s linear infinite;}
@keyframes marquee{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

.m-set{
  display:flex;align-items:center;gap:3rem;
  padding:0 1.5rem;flex-shrink:0;white-space:nowrap;
}
.m-stat{display:flex;align-items:baseline;gap:.6rem;}
.m-num{
  font-family:'Instrument Serif',serif;
  font-size:1.75rem;color:var(--white);letter-spacing:-.02em;line-height:1;
}
.m-lbl{
  font-size:.63rem;letter-spacing:.15em;text-transform:uppercase;
  color:rgba(248,247,245,.55);font-weight:400;
}
.m-sep{width:4px;height:4px;background:var(--gold);border-radius:50%;flex-shrink:0;opacity:.55;}

/* ── SHARED SECTION ── */
.eyebrow{
  display:flex;align-items:center;gap:.75rem;
  margin-bottom:1.3rem;
  font-family:'Instrument Serif',serif;
  font-style:italic;font-size:1rem;color:var(--gold);
}
.eyebrow::before{
  content:'';width:22px;height:1px;
  background:var(--gold);opacity:.45;flex-shrink:0;
}

.section-title{
  font-family:'Instrument Serif',serif;
  font-size:clamp(1.9rem,3.2vw,2.8rem);
  font-weight:400;line-height:1.15;
  color:var(--white);letter-spacing:-.02em;
}

/* ── SERVICES — white section ── */
.services{
  padding:7rem 0;
  background:#ffffff;
  border-top:4px solid var(--hero-blue);
}

.services .eyebrow{color:var(--gold-dk);}
.services .eyebrow::before{background:var(--gold-dk);}
.services .section-title{color:var(--hero-blue);}

.svc-head{
  display:flex;flex-direction:column;align-items:flex-start;
  margin-bottom:4rem;gap:1.2rem;
}
.svc-head-desc{max-width:520px;font-size:1rem;line-height:1.82;color:var(--ink-2);}

.svc-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1.5rem;
}
.svc{
  background:#f8f7f5;
  border:1px solid rgba(20,37,64,.1);
  border-top:3px solid var(--gold);
  padding:2.8rem 2.2rem;
  box-shadow:0 2px 12px rgba(20,37,64,.06);
  transition:box-shadow .35s ease, transform .35s ease, border-top-color .35s ease, background .35s ease;
}
.svc:hover{
  box-shadow:0 20px 56px rgba(20,37,64,.14);
  transform:translateY(-5px);
  border-top-color:var(--hero-blue);
  background:#f8f7f5;
}

.svc-n{font-size:.58rem;letter-spacing:.15em;color:var(--ink-3);margin-bottom:1.8rem;}
.svc-icon{width:50px;height:50px;color:var(--gold-dk);margin-bottom:1.6rem;}
.svc h3{
  font-family:'Instrument Serif',serif;
  font-size:1.45rem;font-weight:400;letter-spacing:-.01em;
  color:var(--hero-blue);margin-bottom:.85rem;
}
.svc p{font-size:1rem;line-height:1.82;color:var(--ink-2);margin-bottom:2rem;}
.svc-link{
  display:inline-flex;align-items:center;gap:.5rem;
  font-size:.7rem;font-weight:500;letter-spacing:.08em;
  color:var(--gold-dk);text-decoration:none;transition:gap .3s ease, color .3s ease;
}
.svc-link:hover{gap:.8rem;color:var(--hero-blue);}

/* ── ABOUT ── */
.about{
  background:var(--linen);
  border-top:4px solid var(--gold);
}
.about-grid{display:grid;grid-template-columns:1fr 1fr;}

.about-text{padding:7rem clamp(1.5rem,5vw,6rem) 9rem;}
.about-text .section-title{margin-bottom:2rem;color:var(--hero-blue);}
.about-body{font-size:1rem;line-height:1.9;color:var(--linen-ink-2);margin-bottom:1.4rem;}

.about-pills{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:2rem;}
.pill{
  padding:.38rem 1rem;
  border:1px solid rgba(20,37,64,.15);
  font-size:.68rem;font-weight:400;letter-spacing:.06em;text-transform:uppercase;
  color:var(--hero-blue);
  transition:border-color .3s ease,color .3s ease,background .3s ease;
}
.pill:hover{border-color:var(--hero-blue);background:var(--hero-blue);color:#fff;}

.about-imgs{position:relative;overflow:hidden;min-height:560px;}
.about-img-a{position:absolute;top:0;left:0;right:0;bottom:0;overflow:hidden;}
.about-img-b{display:none;}
.about-imgs img{width:100%;height:100%;object-fit:cover;opacity:.88;filter:saturate(.75);object-position:center center;}
.about-img-a img{object-position:center center;}

.about .eyebrow{color:var(--gold-dk);}
.about .eyebrow::before{background:var(--gold-dk);}

/* ── PROCESS ── */
.process{
  padding:7rem 0;
  background:#ffffff;
  border-top:4px solid var(--gold);
  position:relative;
  overflow:hidden;
}

/* Subtle warm tint in corner */
.process::after{
  content:'';
  position:absolute;
  top:0;right:0;
  width:480px;height:480px;
  background:radial-gradient(ellipse at top right, rgba(184,146,106,.07) 0%, transparent 70%);
  pointer-events:none;
}

.process .eyebrow{color:var(--gold-dk);}
.process .eyebrow::before{background:var(--gold-dk);}
.process .section-title{color:var(--hero-blue);}

.process-header{
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:1.2rem;
  margin:0 0 5rem;
  max-width:620px;
}

.process-header-left{}

.process-desc{
  font-size:1rem;
  line-height:1.85;
  color:var(--ink-2);
}

/* Timeline */
.process-timeline{
  position:relative;
  max-width:100%;
  margin:0;
}

/* Gold spine */
.process-timeline::before{
  content:'';
  position:absolute;
  left:0;top:0;bottom:0;
  width:2px;
  background:linear-gradient(to bottom, var(--gold) 0%, rgba(184,146,106,.15) 100%);
}

/* Each step */
.pc{
  display:grid;
  grid-template-columns:100px 1fr;
  gap:0;
  padding:0;
  position:relative;
  border-bottom:none;
  margin-bottom:2px;
}
.pc:last-child{ margin-bottom:0; }

/* Dot on spine */
.pc::before{
  content:'';
  position:absolute;
  left:-4px;
  top:2.8rem;
  width:10px;height:10px;
  border-radius:50%;
  background:#ffffff;
  border:2px solid var(--gold);
  box-shadow:0 0 0 3px rgba(184,146,106,.12);
  transition:background .3s ease, transform .3s ease, box-shadow .3s ease;
  z-index:1;
}
.pc:hover::before{
  background:var(--gold);
  transform:scale(1.3);
  box-shadow:0 0 0 5px rgba(184,146,106,.15);
}

/* Step number */
.pc-n{
  font-family:'Instrument Serif',serif;
  font-size:2.4rem;
  font-weight:400;
  font-style:italic;
  color:rgba(184,146,106,.25);
  line-height:1;
  padding:2.2rem 0 2.2rem 2rem;
  flex-shrink:0;
  transition:color .3s ease;
  align-self:start;
}
.pc:hover .pc-n{
  color:var(--gold);
}

/* Content card */
.pc-content{
  background:#f8f7f5;
  border-left:2px solid transparent;
  padding:2.2rem 2.4rem;
  transition:border-color .3s ease, background .3s ease, transform .3s ease;
}
.pc:hover .pc-content{
  border-left-color:var(--gold);
  background:#ffffff;
  transform:translateX(4px);
  box-shadow:0 4px 24px rgba(26,31,46,.06);
}

.pc-content h3{
  font-family:'Instrument Serif',serif;
  font-size:1.45rem;
  font-weight:400;
  letter-spacing:-.02em;
  color:var(--ink);
  margin-bottom:.75rem;
  line-height:1.2;
}
.pc-content p{
  font-size:1rem;
  line-height:1.82;
  color:var(--ink-2);
  max-width:560px;
}

@media(max-width:768px){
  .pc{grid-template-columns:60px 1fr;}
  .pc-n{font-size:1.8rem;padding:1.8rem 0 1.8rem 1.4rem;}
  .pc-content{padding:1.8rem 1.4rem;}
}

/* ── INDUSTRY SPECIALTIES — SLIDER ── */
/* ── INDUSTRY SPECIALTIES — SPLIT SCREEN ── */
.specialties{
  padding:7rem 0;
  background:#f8f7f5;
}

.specialties .eyebrow{color:var(--gold-dk);}
.specialties .eyebrow::before{background:var(--gold-dk);}
.specialties .section-title{color:var(--hero-blue);}

.spec-intro{
  margin-bottom:4rem;
  max-width:520px;
}
.spec-intro .section-title{margin-bottom:1rem;}
.spec-intro-desc{
  font-size:1rem;
  line-height:1.82;
  color:var(--ink-2);
}

/* Split layout */
.spec-split{
  display:grid;
  grid-template-columns:1fr 1fr;
  min-height:560px;
  border:1px solid rgba(20,37,64,.12);
  overflow:hidden;
  box-shadow:0 16px 64px rgba(20,37,64,.12);
}

/* Left — list */
.spec-list{
  background:#ffffff;
  border-right:1px solid rgba(20,37,64,.08);
}

.spec-list-item{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:1.6rem 2.2rem;
  border-bottom:1px solid rgba(20,37,64,.06);
  cursor:pointer;
  position:relative;
  transition:background .25s ease;
  gap:1rem;
}
.spec-list-item:last-child{border-bottom:none;}

.spec-list-item::before{
  content:'';
  position:absolute;
  left:0;top:0;bottom:0;
  width:4px;
  background:linear-gradient(to bottom, var(--gold-lt), var(--gold-dk));
  transform:scaleY(0);
  transform-origin:bottom;
  transition:transform .3s cubic-bezier(.77,0,.175,1);
}
.spec-list-item.active::before,
.spec-list-item:hover::before{transform:scaleY(1);}

.spec-list-item.active{background:#eef0f5;}
.spec-list-item:hover{background:#f4f5f8;}

.spec-list-num{
  font-family:'Instrument Serif',serif;
  font-size:.9rem;
  font-style:italic;
  color:rgba(20,37,64,.25);
  min-width:2rem;
  flex-shrink:0;
  transition:color .25s ease;
}
.spec-list-item.active .spec-list-num,
.spec-list-item:hover .spec-list-num{color:var(--gold);}

.spec-list-name{
  font-family:'Instrument Serif',serif;
  font-size:1.05rem;
  font-weight:400;
  color:var(--ink);
  flex:1;
  letter-spacing:-.01em;
  transition:color .25s ease;
}
.spec-list-item.active .spec-list-name{color:var(--hero-blue);font-weight:500;}
.spec-list-item.active .spec-list-num{color:var(--gold);}
.spec-list-tag{
  font-size:.55rem;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--gold-dk);
  opacity:.7;
  flex-shrink:0;
}

.spec-list-arrow{
  width:18px;height:18px;
  stroke:rgba(20,37,64,.2);
  fill:none;
  stroke-width:1.5;
  stroke-linecap:round;
  stroke-linejoin:round;
  flex-shrink:0;
  transition:stroke .25s ease, transform .25s ease;
}
.spec-list-item.active .spec-list-arrow,
.spec-list-item:hover .spec-list-arrow{
  stroke:var(--hero-blue);
  transform:translateX(3px);
}

/* Right — detail panel */
.spec-panel{
  background:var(--hero-blue);
  padding:3.5rem;
  position:relative;
  overflow:hidden;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
}

/* Decorative radial glow */
.spec-panel::before{
  content:'';
  position:absolute;
  top:-20%;right:-20%;
  width:80%;height:80%;
  background:radial-gradient(ellipse at center, rgba(184,146,106,.18) 0%, transparent 65%);
  pointer-events:none;
}

/* Large decorative number */
.spec-panel-num{
  position:absolute;
  top:2rem;right:2.5rem;
  font-family:'Instrument Serif',serif;
  font-size:clamp(6rem,12vw,10rem);
  font-weight:400;
  font-style:italic;
  color:rgba(255,255,255,.04);
  line-height:1;
  letter-spacing:-.04em;
  user-select:none;
  transition:opacity .4s ease;
}

.spec-panel-content{
  position:relative;
  z-index:1;
}

.spec-panel-tag{
  display:inline-block;
  margin-bottom:1.5rem;
  font-size:.58rem;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--gold-lt);
  opacity:.75;
  padding:.3rem .8rem;
  border:1px solid rgba(184,146,106,.25);
}

.spec-panel-name{
  font-family:'Instrument Serif',serif;
  font-size:clamp(1.8rem,3vw,2.6rem);
  font-weight:400;
  color:#ffffff;
  line-height:1.1;
  letter-spacing:-.02em;
  margin-bottom:1.5rem;
}

.spec-panel-desc{
  font-size:1rem;
  line-height:1.82;
  color:rgba(248,247,245,.55);
  max-width:420px;
}

/* Gold rule above content */
.spec-panel-rule{
  width:36px;height:2px;
  background:var(--gold);
  margin-bottom:1.5rem;
  opacity:.7;
}

/* Transition states */
.spec-panel-content{
  transition:opacity .35s ease, transform .35s cubic-bezier(.16,1,.3,1);
}
.spec-panel-content.transitioning{
  opacity:0;
  transform:translateY(12px);
}

/* Mobile */
@media(max-width:860px){
  .spec-split{grid-template-columns:1fr;min-height:auto;}
  .spec-panel{min-height:320px;padding:2.5rem;}
  .spec-panel-num{font-size:5rem;}
}

/* ── CONTACT ── */
.contact{padding:7rem 0;background:var(--hero-blue);border-top:1px solid rgba(184,146,106,.12);}
.contact-inner{max-width:480px;margin:0 auto;text-align:center;}
.contact-inner .eyebrow{justify-content:center;}
.contact-inner .eyebrow::before{display:none;}
.contact-inner .section-title{margin-bottom:3rem;}

.contact-rows{display:flex;flex-direction:column;gap:2rem;align-items:center;}
.c-row{display:flex;flex-direction:column;align-items:center;gap:.35rem;}
.c-lbl{font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);font-weight:500;}
.c-val{font-size:1rem;color:var(--muted);}
.c-val a{color:inherit;text-decoration:none;transition:color .3s ease;}
.c-val a:hover{color:var(--white);}

/* ── FOOTER ── */
footer{
  padding:2.5rem clamp(1.5rem,5vw,6rem) 5rem;
  background:var(--hero-blue);
  border-top:1px solid rgba(184,146,106,.10);
}
.footer-inner{display:flex;justify-content:space-between;align-items:center;}
.f-logo{
  font-family:'Instrument Serif',serif;
  font-size:1.05rem;
  color:rgba(248,247,245,.45);
  letter-spacing:.03em;
  text-transform:uppercase;
}
.f-logo-amp{font-style:italic;color:var(--gold);opacity:.85;}
.f-links{display:flex;gap:2rem;list-style:none;}
.f-links a{
  font-size:.67rem;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(248,247,245,.42);text-decoration:none;transition:color .3s ease;
}
.f-links a:hover{color:rgba(248,247,245,.75);}
.f-copy{font-size:.64rem;letter-spacing:.04em;color:rgba(248,247,245,.3);}

/* ── SCROLL REVEAL ── */
.reveal{
  opacity:0;
  transform:translateY(28px);
  transition:opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1);
}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-delay-1{transition-delay:.1s;}
.reveal-delay-2{transition-delay:.2s;}
.reveal-delay-3{transition-delay:.3s;}

/* ── RESPONSIVE ── */
@media(max-width:1024px){
  .hero-bottom{flex-direction:column;align-items:flex-start;gap:2.5rem;}
  .svc-grid{grid-template-columns:1fr;}
  .about-grid{grid-template-columns:1fr;}
  .about-imgs{min-height:340px;}
  .spec-grid{grid-template-columns:repeat(2,1fr);}
  .spec-head{flex-direction:column;align-items:flex-start;gap:1.5rem;}
  .accordion{flex-direction:column;height:auto;}
  .acc-item{flex:0 0 56px;}
  .acc-item.open{flex:0 0 auto;}
  .acc-label{transform:translate(-50%,-50%);writing-mode:horizontal-tb;font-size:.8rem;}
  .acc-content{position:relative;opacity:0;height:0;padding:0 2rem;transition:opacity .3s ease, height .4s ease, padding .4s ease;}
  .acc-item.open .acc-content{opacity:1;height:auto;padding:1.5rem 2rem 2rem;}
  .acc-num{top:0.5rem;right:1.5rem;font-size:3rem;}
}
@media(max-width:640px){
  .footer-inner{flex-direction:column;gap:1.5rem;text-align:center;}
  .f-links{flex-wrap:wrap;justify-content:center;order:-1;}
  .m-set{gap:2rem;}
  .spec-grid{grid-template-columns:1fr;}
}
</style>

  <link rel="apple-touch-icon" href="apple-touch-icon.png">
</head>
<body>

<!-- NAV -->
<nav id="navbar">
  <a href="#" class="nav-logo">AGeorge <span class="nav-logo-amp">&amp;</span> Co.</a>
</nav>

<!-- MENU BTN — fixed independently above everything -->
<div class="menu-btn-wrap" id="menuBtnWrap">
  <button class="menu-btn" id="menuBtn" aria-label="Menu">
    <svg width="44" height="36" viewBox="0 0 44 36" style="display:block;overflow:visible;">
      <path id="ml1" class="m-line m-line-1" d="M6,12 H38 C47,12 47,0 38,6 L6,30"/>
      <path id="ml2" class="m-line m-line-2" d="M38,24 H22 C29,24 38,26 38,30 L6,6"/>
    </svg>
    <span class="menu-word" id="menuWord">Menu</span>
  </button>
</div>

<!-- OVERLAY -->
<div class="nav-overlay" id="navOverlay">
  <div class="nav-panel">
    <div class="nav-item"><a href="#services">Services</a></div>
    <div class="nav-item"><a href="#about">About</a></div>
    <div class="nav-item"><a href="#process">Process</a></div>
    <div class="nav-item"><a href="#contact">Contact</a></div>
    <div class="panel-foot">
      <div class="panel-contact">
        <div class="panel-contact-item">
          <span class="panel-contact-label">Email</span>
          <a href="mailto:info@ageorgeco.com">info@ageorgeco.com</a>
        </div>
        <div class="panel-contact-item">
          <span class="panel-contact-label">Tel</span>
          <span>718-407-0532</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- HERO -->
<section class="hero">

  <div class="hero-eyebrow">
    <span class="hero-ey-line"></span>
    <span class="hero-ey-text">M&amp;A Advisory</span>
  </div>
  <h1>Strategic, <em>confidential</em><br>advisory for principals.</h1>
  <div class="hero-bottom">
    <p class="hero-desc">Specialist M&amp;A advisory for facility management businesses. We take on few mandates — and bring the full weight of our expertise to every one.</p>
    <a href="#services" class="hero-cta">
      <span class="hero-cta-label">Explore our services</span>
      <span class="hero-cta-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </a>
  </div>
</section>

<!-- MARQUEE -->
<section class="marquee-wrap" aria-label="Firm statistics">
  <div class="marquee-track">
    <div class="m-set">
      <div class="m-stat"><span class="m-num">Facility Management</span><span class="m-lbl">Sector Focus</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">100%</span><span class="m-lbl">Dedicated to Clients</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Sell-Side</span><span class="m-lbl">&amp; Buy-Side</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Middle Market</span><span class="m-lbl">Transaction Focus</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Principal-Led</span><span class="m-lbl">Every Engagement</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Complete</span><span class="m-lbl">Confidentiality</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">New York</span><span class="m-lbl">Headquartered</span></div>
      <span class="m-sep"></span>
    </div>
    <div class="m-set" aria-hidden="true">
      <div class="m-stat"><span class="m-num">Facility Management</span><span class="m-lbl">Sector Focus</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">100%</span><span class="m-lbl">Dedicated to Clients</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Sell-Side</span><span class="m-lbl">&amp; Buy-Side</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Middle Market</span><span class="m-lbl">Transaction Focus</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Principal-Led</span><span class="m-lbl">Every Engagement</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">Complete</span><span class="m-lbl">Confidentiality</span></div>
      <span class="m-sep"></span>
      <div class="m-stat"><span class="m-num">New York</span><span class="m-lbl">Headquartered</span></div>
      <span class="m-sep"></span>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="services" id="services">
  <div class="wrap">
    <div class="svc-head reveal">
      <div>
        <div class="eyebrow">What We Do</div>
        <h2 class="section-title">Advisory<br>Services</h2>
      </div>
      <p class="svc-head-desc">We focus exclusively on sell-side and buy-side M&amp;A within the facility management sector — bringing deep industry knowledge and disciplined execution to every engagement.</p>
    </div>
    <div class="svc-grid">
      <div class="svc reveal reveal-delay-1">
        <div class="svc-n">01</div>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" stroke-linejoin="round">
          <!-- Pediment / roof -->
          <polyline points="2,8 12,2 22,8"/>
          <!-- Cornice lines -->
          <line x1="2" y1="8" x2="22" y2="8"/>
          <line x1="3" y1="9.5" x2="21" y2="9.5"/>
          <!-- Columns -->
          <line x1="5"  y1="9.5" x2="5"  y2="19"/>
          <line x1="8.5" y1="9.5" x2="8.5" y2="19"/>
          <line x1="12" y1="9.5" x2="12" y2="19"/>
          <line x1="15.5" y1="9.5" x2="15.5" y2="19"/>
          <line x1="19" y1="9.5" x2="19" y2="19"/>
          <!-- Stylobate steps -->
          <line x1="3"   y1="19"   x2="21"   y2="19"/>
          <line x1="2"   y1="20.5" x2="22"   y2="20.5"/>
          <line x1="1"   y1="22"   x2="23"   y2="22"/>
        </svg>
        <h3>Sell-Side Advisory</h3>
        <p>Comprehensive representation for business owners considering a sale — from valuation and positioning through buyer outreach, negotiation, and a successful close. Confidential from start to finish.</p>
        <a href="#process" class="svc-link">Our Process <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
      <div class="svc reveal reveal-delay-2">
        <div class="svc-n">02</div>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" stroke-linejoin="round">
          <!-- Candlestick chart — markets/acquisition signal -->
          <!-- Candle 1 -->
          <line x1="4"  y1="5"  x2="4"  y2="19"/>
          <rect x="2.5" y="8"  width="3" height="7"/>
          <!-- Candle 2 -->
          <line x1="9"  y1="4"  x2="9"  y2="18"/>
          <rect x="7.5" y="6"  width="3" height="8"/>
          <!-- Candle 3 -->
          <line x1="14" y1="7"  x2="14" y2="20"/>
          <rect x="12.5" y="10" width="3" height="7"/>
          <!-- Candle 4 -->
          <line x1="19" y1="3"  x2="19" y2="17"/>
          <rect x="17.5" y="5"  width="3" height="6"/>
        </svg>
        <h3>Buy-Side Advisory</h3>
        <p>Disciplined acquisition support for private equity firms and strategic acquirers targeting facility management businesses — from target identification and diligence through closing and integration planning.</p>
        <a href="#process" class="svc-link">Our Process <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
      <div class="svc reveal reveal-delay-3">
        <div class="svc-n">03</div>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" stroke-linejoin="round">
          <!-- Spire — tall and fine -->
          <line x1="12" y1="0.5" x2="12" y2="4"/>
          <line x1="11.2" y1="4" x2="12.8" y2="4"/>
          <!-- Top tower — very narrow, tall -->
          <line x1="11.2" y1="4"  x2="11.2" y2="9"/>
          <line x1="12.8" y1="4"  x2="12.8" y2="9"/>
          <!-- First setback — tiny step -->
          <line x1="11.2" y1="9"  x2="10"   y2="9"/>
          <line x1="12.8" y1="9"  x2="14"   y2="9"/>
          <!-- Second tower — still narrow -->
          <line x1="10"   y1="9"  x2="10"   y2="14"/>
          <line x1="14"   y1="9"  x2="14"   y2="14"/>
          <!-- Floor line -->
          <line x1="10"   y1="11.5" x2="14" y2="11.5"/>
          <!-- Second setback -->
          <line x1="10"   y1="14" x2="8.5"  y2="14"/>
          <line x1="14"   y1="14" x2="15.5" y2="14"/>
          <!-- Base tower — only slightly wider -->
          <line x1="8.5"  y1="14" x2="8.5"  y2="22"/>
          <line x1="15.5" y1="14" x2="15.5" y2="22"/>
          <!-- Base mullions — keep narrow -->
          <line x1="10"   y1="14" x2="10"   y2="22"/>
          <line x1="12"   y1="14" x2="12"   y2="22"/>
          <line x1="14"   y1="14" x2="14"   y2="22"/>
          <!-- Base floor lines — sparse -->
          <line x1="8.5"  y1="16.5" x2="15.5" y2="16.5"/>
          <line x1="8.5"  y1="19"   x2="15.5" y2="19"/>
          <!-- Ground -->
          <line x1="6"    y1="22"   x2="18"   y2="22"/>
          <line x1="5"    y1="23"   x2="19"   y2="23"/>
        </svg>
        <h3>Transaction Management</h3>
        <p>End-to-end deal management for clients who need more than advice — process architecture, data room preparation, counterparty coordination, and senior oversight through every phase of execution.</p>
        <a href="#process" class="svc-link">Our Process <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="about-grid">
    <div class="about-text reveal">
      <div class="eyebrow">About AGeorge &amp; Co.</div>
      <h2 class="section-title">Selective by Design.<br>Committed to Results.</h2>
      <p class="about-body">AGeorge &amp; Co. is a specialized M&amp;A advisory practice focused exclusively on the facility management industry — janitorial, soft services, hard services, and building services businesses across the middle market.</p>
      <p class="about-body">We work with a limited number of clients at any time. That selectivity is intentional — it is how we ensure that every engagement receives the full strategic attention, deep sector knowledge, and complete discretion it deserves. Transactions are never discussed until they are done.</p>
      <div class="about-pills">
        <span class="pill">Senior-Level Attention</span>
        <span class="pill">Conflict-Free Advice</span>
        <span class="pill">Proprietary Buyer Network</span>
        <span class="pill">Complete Confidentiality</span>
      </div>
    </div>
    <div class="about-imgs">
      <div class="about-img-a">
    <img src>
      </div>
      <div class="about-img-b" style="display:none;">
        <img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?w=900&q=85&fit=crop" alt="Office interior"/>
      </div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="process" id="process">
  <div class="wrap">

    <div class="process-header reveal">
      <div class="eyebrow">Our Approach</div>
      <h2 class="section-title">A Disciplined<br>Process</h2>
      <p class="process-desc">Every engagement follows our proven methodology while remaining flexible to the unique dynamics of your situation. Senior attention at every stage — not just at the start.</p>
    </div>

    <div class="process-timeline">

      <div class="pc reveal">
        <div class="pc-n">01</div>
        <div class="pc-content">
          <h3>Strategic Assessment</h3>
          <p>A thorough review of your business, objectives, and market context — building a clear transaction strategy tailored to your situation and goals.</p>
        </div>
      </div>

      <div class="pc reveal">
        <div class="pc-n">02</div>
        <div class="pc-content">
          <h3>Market Preparation</h3>
          <p>Institutional-quality materials and a targeted buyer list — drawing on deep sector relationships and proprietary knowledge of the FM landscape.</p>
        </div>
      </div>

      <div class="pc reveal">
        <div class="pc-n">03</div>
        <div class="pc-content">
          <h3>Targeted Outreach</h3>
          <p>A controlled, fully confidential process — engaging only the right parties, maintaining competitive tension, and protecting your business throughout.</p>
        </div>
      </div>

      <div class="pc reveal">
        <div class="pc-n">04</div>
        <div class="pc-content">
          <h3>Negotiation &amp; Close</h3>
          <p>Senior-led representation from term sheet through closing — coordinating all parties, managing complexity, and driving toward the best possible outcome.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- INDUSTRY SPECIALTIES -->
<section class="specialties">
  <div class="wrap">

    <div class="spec-intro reveal">
      <div class="eyebrow">Sector Focus</div>
      <h2 class="section-title">Facility Management<br>M&amp;A</h2>
      <p class="spec-intro-desc">We work exclusively within the facility management industry — a sector we know from the inside. That depth shapes every conversation, every valuation, and every negotiation we lead.</p>
    </div>

    <div class="spec-split reveal">

      <!-- Left: list -->
      <div class="spec-list" id="specList">
        <div class="spec-list-item active" data-index="0">
          <span class="spec-list-num">01</span>
          <span class="spec-list-name">Janitorial &amp; Soft Services</span>
          <span class="spec-list-tag">Core</span>
          <svg class="spec-list-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
        <div class="spec-list-item" data-index="1">
          <span class="spec-list-num">02</span>
          <span class="spec-list-name">Hard Services &amp; Maintenance</span>
          <span class="spec-list-tag">Core</span>
          <svg class="spec-list-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
        <div class="spec-list-item" data-index="2">
